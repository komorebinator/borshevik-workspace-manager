<?xml version="1.0" encoding="UTF-8"?>
<schemalist>
  <schema id="org.gnome.shell.extensions.borshevik-workspace-manager" path="/org/gnome/shell/extensions/borshevik-workspace-manager/">
    <key name="debug-logging" type="b">
      <default>false</default>
      <summary>Debug logging</summary>
      <description>When enabled, writes diagnostic messages to the system journal.</description>
    </key>
    <key name="overview-on-last-workspace" type="b">
      <default>true</default>
      <summary>Open overview when switching to the last workspace</summary>
      <description>Automatically opens the GNOME overview when the active workspace becomes the last (empty) one.</description>
    </key>
    <key name="float-sizes" type="s">
      <default>'{}'</default>
      <summary>Saved float sizes per window class</summary>
      <description>JSON map of wm_class → {wr, hr} fractions of work area, saved when a floating window is tiled by the user.</description>
    </key>
    <key name="tile-left" type="as">
      <default>['&lt;Super&gt;Left']</default>
      <summary>Tile focused window to the left</summary>
    </key>
    <key name="tile-right" type="as">
      <default>['&lt;Super&gt;Right']</default>
      <summary>Tile focused window to the right</summary>
    </key>
    <key name="open-rules-ui" type="as">
      <default>['&lt;Super&gt;r']</default>
      <summary>Open window rules UI</summary>
    </key>
    <key name="window-rules" type="s">
      <default>'[{"id":"48b69c51-cdff-48af-b8fa-8fb1387ff3c6","conditions":{"class":{"enabled":true,"regex":"steam"},"title":{"enabled":false,"regex":"Steam"},"onAllWorkspaces":{"enabled":false,"value":false},"above":{"enabled":false,"value":false},"skipTaskbar":{"enabled":false,"value":false},"fullscreen":{"enabled":false,"value":false},"maximized":{"enabled":false,"value":false}},"actions":{"onAllWorkspaces":{"enabled":false,"value":true},"above":{"enabled":false,"value":true},"openOnNewWorkspace":{"enabled":true,"value":true},"geometry":{"enabled":false,"x":15,"y":16,"w":74,"h":76}}},{"id":"7ae26d26-0fbc-40e8-9add-48244cc78266","conditions":{"class":{"enabled":false,"regex":""},"title":{"enabled":true,"regex":"Picture in picture"},"onAllWorkspaces":{"enabled":false,"value":false},"above":{"enabled":false,"value":false},"skipTaskbar":{"enabled":false,"value":false},"fullscreen":{"enabled":false,"value":false},"maximized":{"enabled":false,"value":false}},"actions":{"onAllWorkspaces":{"enabled":true,"value":true},"above":{"enabled":true,"value":true},"openOnNewWorkspace":{"enabled":false,"value":true},"geometry":{"enabled":true,"x":0,"y":60,"w":40,"h":40}}},{"id":"496453af-fb67-41d4-a9f8-3994b62c6bc1","conditions":{"class":{"enabled":true,"regex":"it.mijorus.collector"},"title":{"enabled":false,"regex":"CollectorMainWindow"},"onAllWorkspaces":{"enabled":false,"value":false},"above":{"enabled":false,"value":false},"skipTaskbar":{"enabled":false,"value":false},"fullscreen":{"enabled":false,"value":false},"maximized":{"enabled":false,"value":false}},"actions":{"onAllWorkspaces":{"enabled":true,"value":true},"above":{"enabled":true,"value":true},"openOnNewWorkspace":{"enabled":false,"value":true},"geometry":{"enabled":false,"x":40,"y":36,"w":21,"h":29}}}]'</default>
      <summary>Window rules</summary>
      <description>JSON array of window rule objects with conditions and actions.</description>
    </key>
    <key name="on-empty-workspace" type="s">
      <default>'prev'</default>
      <summary>Action when last window on workspace is closed</summary>
      <description>What to do when the active workspace becomes empty. "prev" navigates to the adjacent workspace, "overview" opens the GNOME overview, "nothing" does nothing.</description>
      <choices>
        <choice value="prev"/>
        <choice value="overview"/>
        <choice value="nothing"/>
      </choices>
    </key>
  </schema>
</schemalist>
